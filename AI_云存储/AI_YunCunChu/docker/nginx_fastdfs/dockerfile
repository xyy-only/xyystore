# ========== 阶段 1：构建前端 ==========
FROM node:18-alpine AS frontend-builder
WORKDIR /app
COPY picture_bed/package.json picture_bed/package-lock.json* ./
RUN npm install
COPY picture_bed/ ./
RUN npm run build

# ========== 阶段 2：构建 nginx + fastdfs ==========
FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai

# 安装基础依赖
RUN apt-get update && apt-get install -y \
    gcc g++ make \
    wget curl vim lsof procps \
    ca-certificates \
    libtool automake autoconf \
    libpcre3-dev libssl-dev zlib1g-dev openssl \
    && rm -rf /var/lib/apt/lists/*

# 复制预下载的依赖源码
COPY deps/libfastcommon-V1.0.43.tar.gz /tmp/
COPY deps/fastdfs-V6.06.tar.gz /tmp/
COPY deps/fastdfs-nginx-module-V1.22.tar.gz /tmp/

# 编译安装 libfastcommon V1.0.43
RUN cd /tmp && \
    tar xzf libfastcommon-V1.0.43.tar.gz && \
    cd libfastcommon-1.0.43 && \
    ./make.sh && ./make.sh install && \
    ldconfig && \
    rm -rf /tmp/libfastcommon-1.0.43 /tmp/libfastcommon-V1.0.43.tar.gz

# 编译安装 FastDFS V6.06，并复制 http.conf 和 mime.types
RUN cd /tmp && \
    tar xzf fastdfs-V6.06.tar.gz && \
    cd fastdfs-6.06 && \
    ./make.sh && ./make.sh install && \
    ldconfig && \
    cp conf/http.conf /etc/fdfs/http.conf && \
    cp conf/mime.types /etc/fdfs/mime.types && \
    rm -rf /tmp/fastdfs-6.06 /tmp/fastdfs-V6.06.tar.gz

# 编译安装 fastdfs-nginx-module V1.22 + nginx
RUN cd /tmp && \
    tar xzf fastdfs-nginx-module-V1.22.tar.gz && \
    wget http://nginx.org/download/nginx-1.20.2.tar.gz && \
    tar xzf nginx-1.20.2.tar.gz && \
    cd nginx-1.20.2 && \
    ./configure --prefix=/usr/local/nginx \
        --add-module=/tmp/fastdfs-nginx-module-1.22/src \
        --with-http_ssl_module && \
    make && make install && \
    rm -rf /tmp/nginx-1.20.2 /tmp/nginx-1.20.2.tar.gz /tmp/fastdfs-nginx-module-1.22 /tmp/fastdfs-nginx-module-V1.22.tar.gz

# 创建必要目录
RUN mkdir -p /fastdfs_data_and_log/tracker \
    /fastdfs_data_and_log/storage \
    /fastdfs_data_and_log/client \
    /etc/fdfs \
    /app/front

# 生成自签名 SSL 证书（10年有效期）
RUN mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 3650 \
        -newkey rsa:2048 \
        -keyout /etc/nginx/ssl/server.key \
        -out /etc/nginx/ssl/server.crt \
        -subj "/C=CN/ST=Beijing/L=Beijing/O=YunCunChu/CN=xxx.xx.xx.xx" \
        -addext "subjectAltName=IP:xxx.xx.xx.xx"

# 复制 FastDFS 配置模板
RUN cp /etc/fdfs/tracker.conf.sample /etc/fdfs/tracker.conf && \
    cp /etc/fdfs/storage.conf.sample /etc/fdfs/storage.conf && \
    cp /etc/fdfs/client.conf.sample /etc/fdfs/client.conf && \
    cp /etc/fdfs/http.conf /etc/fdfs/http.conf.bak || true && \
    cp /etc/fdfs/mime.types /etc/fdfs/mime.types.bak || true

# 复制前端构建产物（来自阶段 1）
COPY --from=frontend-builder /app/build/ /app/front/
# 复制 nginx 配置和启动脚本
COPY docker/nginx_fastdfs/nginx.conf /usr/local/nginx/conf/nginx.conf
COPY docker/nginx_fastdfs/start.sh /app/start.sh
COPY docker/nginx_fastdfs/tracker.conf /etc/fdfs/tracker.conf
COPY docker/nginx_fastdfs/storage.conf /etc/fdfs/storage.conf
COPY docker/nginx_fastdfs/client.conf /etc/fdfs/client.conf
COPY docker/nginx_fastdfs/mod_fastdfs.conf /etc/fdfs/mod_fastdfs.conf
RUN chmod +x /app/start.sh

EXPOSE 80 443 22122 23000

CMD ["/app/start.sh"]
